# Gateway
PORT=9080
NODE_ENV=development

# Redis (Gateway Rate Limiting & WebSocket scaling)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=dev-secret-key-do-not-use-in-production

# Google OAuth/OIDC
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:9080/api/auth/oauth2/google/callback

# Frontend redirect targets
DISCORD_FRONTEND_URL=http://localhost:3000/dashboard
PORTAL_FRONTEND_URL=http://localhost:3001/profile

# Cookie behavior for local HTTP dev
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=Lax
AUTH_COOKIE_DOMAIN=

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/discord_mini_users?schema=public

# External Services
RABBITMQ_URL=amqp://localhost:5672
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=
