# ============================================================
# Discord Mini — Backend Environment Variables Template
# Copy khối tương ứng vào file .env của mỗi service
# ============================================================
#
# ⚠️  KHÔNG commit file .env chứa credentials thực lên Git!
# ⚠️  File này chỉ là template — thay <placeholder> bằng giá trị thực.
#
# Kiến trúc 100% Cloud:
#   PostgreSQL  → Supabase
#   MongoDB     → MongoDB Atlas
#   Redis       → Upstash
#   RabbitMQ    → CloudAMQP
#   Storage     → Backblaze B2
# ============================================================

# ─────────────────────────────────────────────
# user-service/.env
# ─────────────────────────────────────────────
# DB_URL=jdbc:postgresql://<supabase-host>:5432/postgres
# DB_USERNAME=postgres.<project-ref>
# DB_PASSWORD=<password>
# JWT_SECRET=<your-256-bit-secret>
# EUREKA_URL=http://localhost:8761/eureka/

# ─────────────────────────────────────────────
# group-channel-service/.env
# ─────────────────────────────────────────────
# DB_URL=jdbc:postgresql://<supabase-host>:5432/postgres
# DB_USERNAME=postgres.<project-ref>
# DB_PASSWORD=<password>
# RABBITMQ_HOST=<cloudamqp-host>
# RABBITMQ_PORT=5671
# RABBITMQ_USER=<username>
# RABBITMQ_PASS=<password>
# RABBITMQ_VHOST=<vhost>
# RABBITMQ_SSL=true
# EUREKA_URL=http://localhost:8761/eureka/

# ─────────────────────────────────────────────
# chat-history-service/.env
# ─────────────────────────────────────────────
# MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
# RABBITMQ_HOST=<cloudamqp-host>
# RABBITMQ_PORT=5671
# RABBITMQ_USER=<username>
# RABBITMQ_PASS=<password>
# RABBITMQ_VHOST=<vhost>
# RABBITMQ_SSL=true
# EUREKA_URL=http://localhost:8761/eureka/

# ─────────────────────────────────────────────
# messaging-service/.env
# ─────────────────────────────────────────────
# REDIS_HOST=<upstash-host>
# REDIS_PORT=6379
# REDIS_PASSWORD=<upstash-token>
# REDIS_SSL=true
# RABBITMQ_HOST=<cloudamqp-host>
# RABBITMQ_PORT=5671
# RABBITMQ_USER=<username>
# RABBITMQ_PASS=<password>
# RABBITMQ_VHOST=<vhost>
# RABBITMQ_SSL=true
# JWT_SECRET=<your-256-bit-secret>
# EUREKA_URL=http://localhost:8761/eureka/

# ─────────────────────────────────────────────
# file-service/.env
# ─────────────────────────────────────────────
# B2_ENDPOINT=https://s3.<region>.backblazeb2.com
# B2_KEY_ID=<key-id>
# B2_APP_KEY=<application-key>
# B2_BUCKET_NAME=<bucket-name>
# EUREKA_URL=http://localhost:8761/eureka/

# ─────────────────────────────────────────────
# api-gateway/.env
# ─────────────────────────────────────────────
# JWT_SECRET=<your-256-bit-secret>
# EUREKA_URL=http://localhost:8761/eureka/
